# Points at the Easycash backend's /api/v1 base path - defaults to localhost:4000 in code if unset,
# but MUST be set to a real, publicly-reachable URL before deploying to GitHub Pages (a cross-origin
# static site can never reach "localhost" - that always means "the visitor's own machine").
VITE_API_BASE_URL=http://localhost:4000/api/v1
